APP_NAME=ConnectEd
DEBUG=True

# MySQL database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=connected_app
DATABASE_URL=mysql+pymysql://root:your_mysql_password@127.0.0.1:3306/connected_app

# JWT — generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_strong_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Anthropic (Claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key

# OpenAI (Whisper / GPT) — https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key

# Google GenAI (Gemini) — https://aistudio.google.com/
GOOGLE_GENAI_API_KEY=your_google_genai_api_key

# Meta WhatsApp Cloud API — https://developers.facebook.com/
WHATSAPP_USE_TEMPLATES=true
META_WHATSAPP_TOKEN=your_meta_whatsapp_token
META_PHONE_NUMBER_ID=your_meta_phone_number_id
META_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token
FRONTEND_URL=http://localhost:5173

# LiveKit video conferencing — https://livekit.io/
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_EGRESS_ENABLED=1
LIVEKIT_RECORDING_DIR=/path/to/connected/backend/uploads/recordings
